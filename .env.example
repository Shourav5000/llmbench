# Anthropic API (required)
ANTHROPIC_API_KEY=your_anthropic_key_here

# LangSmith (required for tracing)
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=claudeeval

# Models to compare (comma-separated)
CLAUDE_MODELS=claude-haiku-4-5-20251001,claude-sonnet-4-6,claude-opus-4-6

# Cost per 1M tokens (input/output) for each model
# Used to calculate cost per evaluation run
HAIKU_INPUT_COST=0.80
HAIKU_OUTPUT_COST=4.00
SONNET_INPUT_COST=3.00
SONNET_OUTPUT_COST=15.00
OPUS_INPUT_COST=15.00
OPUS_OUTPUT_COST=75.00
